# Скопируйте в .env и задайте значения.  cp .env.example .env

# Секрет для подписи JWT-токенов панели. ОБЯЗАТЕЛЬНО смените в проде.
# Сгенерировать:  python -c "import secrets; print(secrets.token_hex(32))"
DEPLOYER_SECRET_KEY=

# Мастер-ключ шифрования секретов at-rest (SecretBox: GitHub-PAT в деплоере,
# чужие токены в ЛК — ADR-032/033). ОБЯЗАТЕЛЬНО задайте в проде, иначе ключ
# генерируется в data/master.key (переживает рестарт, но не переносится между хостами).
# Сгенерировать:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DEPLOYER_MASTER_KEY=

# Контактный email для Let's Encrypt (уведомления об истечении сертификатов).
# Пусто -> регистрация без email (--register-unsafely-without-email).
DEPLOYER_ACME_EMAIL=

# (Необязательно) URL/путь к Docker-сокету. Если не задан — берётся
# платформенный дефолт: unix:///var/run/docker.sock на Linux/macOS,
# npipe:////./pipe/docker_engine на Windows. Переопределяйте для нестандартных
# установок (удалённый Docker, rootless, TCP). Пример: tcp://127.0.0.1:2375
# DOCKER_HOST=

# (Необязательно) Издание/редакция деплоера: oss | pro | cloud (по умолчанию oss).
# Open-core: одна кодовая база, фичи включаются флагом (ADR-019, docs/10_EDITIONS.md).
# Pro/Cloud-код живёт в app/pro и app/cloud (нет в публичном OSS-репозитории).
# DEPLOYER_EDITION=oss

# ===== ЛК / контрол-плейн (cloud-издание; для OSS-деплоера не нужны) =====

# Почтовый транспорт ЛК (П1: коды подтверждения e-mail). SMTP-релей — напр.
# Selectel (адрес/порт/логин из панели почтового сервиса). Пусто = dev-режим
# (письма не уходят). Проверка: супер-админка → «Отправить тестовое письмо».
# CLOUD_SMTP_HOST=
# CLOUD_SMTP_PORT=587
# CLOUD_SMTP_USER=
# CLOUD_SMTP_PASSWORD=
# CLOUD_SMTP_FROM=noreply@exosystem.tech
# CLOUD_SMTP_TLS=true

# Требовать подтверждение e-mail для чувствительных действий (серверы,
# подключения). Включать ТОЛЬКО вместе с настроенным SMTP — иначе пользователи
# не смогут получить код.
# CLOUD_REQUIRE_EMAIL_VERIFICATION=false

# E-mail супер-админа (П3): аккаунт с этой почтой получает роль superadmin
# (на старте ЛК и при регистрации).
# CLOUD_SUPERADMIN_EMAIL=
