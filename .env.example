# Скопируйте в .env и задайте значения.  cp .env.example .env

# Секрет для подписи JWT-токенов панели. ОБЯЗАТЕЛЬНО смените в проде.
# Сгенерировать:  python -c "import secrets; print(secrets.token_hex(32))"
DEPLOYER_SECRET_KEY=

# Мастер-ключ шифрования секретов at-rest (SecretBox: GitHub-PAT в деплоере,
# чужие токены в ЛК — ADR-032/033). ОБЯЗАТЕЛЬНО задайте в проде, иначе ключ
# генерируется в data/master.key (переживает рестарт, но не переносится между хостами).
# Сгенерировать:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DEPLOYER_MASTER_KEY=

# Прод-гейт мастер-ключа (V-04, ADR-074): true → сервис НЕ стартует без
# DEPLOYER_MASTER_KEY из окружения (запрещает fallback на data/master.key —
# файл-ключ рядом с БД раскрывается вместе с любым бэкапом тома).
# DEPLOYER_MASTER_KEY_REQUIRED=false

# Контактный email для Let's Encrypt (уведомления об истечении сертификатов).
# Пусто -> регистрация без email (--register-unsafely-without-email).
DEPLOYER_ACME_EMAIL=

# (Необязательно) URL/путь к Docker-сокету. Если не задан — берётся
# платформенный дефолт: unix:///var/run/docker.sock на Linux/macOS,
# npipe:////./pipe/docker_engine на Windows. Переопределяйте для нестандартных
# установок (удалённый Docker, rootless, TCP). Пример: tcp://127.0.0.1:2375
# DOCKER_HOST=

# (Необязательно) Издание/редакция деплоера: oss | pro | cloud (по умолчанию oss).
# Open-core: одна кодовая база, фичи включаются флагом (ADR-019, docs/10_EDITIONS.md).
# Pro/Cloud-код живёт в app/pro и app/cloud (нет в публичном OSS-репозитории).
# DEPLOYER_EDITION=oss

# (Необязательно) Ожидаемый `aud` PRO-лицензии = идентификатор ЭТОЙ ноды в ЛК
# (её server.id). Вторая (необязательная) страховка привязки лицензии к ноде: сама
# per-node пара cpk уже привязывает подпись. Пусто → aud-привязку не проверяем
# (ADR-100). Обычно закладывается ЛК при провиженинге, вручную задавать не нужно.
# DEPLOYER_CONTROL_PLANE_AUD=

# ===== ЛК / контрол-плейн (cloud-издание; для OSS-деплоера не нужны) =====

# Почтовый транспорт ЛК (П1: коды подтверждения e-mail; 2FA-вход супер-админа).
# Пусто = dev-режим (письма не уходят). Проверка: супер-админка → «Тестовое письмо».
# Транзакционный SMTP Selectel: HOST=smtp.mail.selcloud.ru, USER=<числовой логин>,
# PASSWORD=<API-ключ>, порт 1126 (STARTTLS) ИЛИ 1127 (неявный SSL → CLOUD_SMTP_SSL=true).
# CLOUD_SMTP_HOST=
# CLOUD_SMTP_PORT=587
# CLOUD_SMTP_USER=
# CLOUD_SMTP_PASSWORD=
# FROM — реальный адрес на ВЕРИФИЦИРОВАННОМ в Selectel домене (TXT-ключ в DNS),
# НЕ числовой логин и НЕ чужой ящик (иначе релей отклонит / спам).
# CLOUD_SMTP_FROM=noreply@exosystem.tech
# CLOUD_SMTP_FROM_NAME=EXOSYSTEM   # отображаемое имя отправителя (по умолчанию EXOSYSTEM)
# CLOUD_SMTP_TLS=true    # STARTTLS для обычного SMTP (порт 587 / Selectel 1126)
# CLOUD_SMTP_SSL=false   # неявный SSL с первого байта (порт 465 / Selectel 1127)

# Требовать подтверждение e-mail для чувствительных действий (серверы,
# подключения). Включать ТОЛЬКО вместе с настроенным SMTP — иначе пользователи
# не смогут получить код.
# CLOUD_REQUIRE_EMAIL_VERIFICATION=false

# E-mail супер-админа (П3): аккаунт с этой почтой получает роль superadmin
# (на старте ЛК и при регистрации).
# CLOUD_SUPERADMIN_EMAIL=

# ===== Сетевой замок ноды (V-01/V-02/V-06, ADR-074) =====

# Egress-IP/CIDR контрол-плейна (список через запятую; голый IP → /32).
# Задан → security-group новых нод открывает :7999 ТОЛЬКО этим адресам
# (канал управления ЛК в окне до SSL), а не всему интернету. Владелец в это
# окно попадает в панель по домену (nginx :80/:443); после SSL порт закрывается
# совсем (ADR-054). Пусто → :7999 открыт миру (dev/спайк — как раньше).
# CLOUD_EGRESS_CIDR=203.0.113.5

# Разрешить пароль админа панели по нешифрованному HTTP (только legacy-ноды без
# cpk / локальный dev). Прод — false: ЛК аутентифицируется на нодах одноразовыми
# cpk-токенами (sso/redeem), а перевыпуск пароля (recover) ждёт HTTPS.
# CLOUD_ALLOW_PLAINTEXT_M2M=false

# ===== Платформенный DNS служебной зоны + пул временных доменов (ADR-097) =====

# Провайдер СЛУЖЕБНОЙ зоны платформы (panel-домены нод, app-домены, пул имён).
# selectel — DNS API v2 Selectel (зона на NS a/b/c/d.ns.selectel.ru);
# regru — legacy (API Рег.ру). Пусто = не настроен: записи создаются только
# через Рег.ру-подключения аккаунтов (прежнее поведение), пул спит.
# PLATFORM_DNS_PROVIDER=selectel
# PLATFORM_DNS_ZONE=exosystem.tech

# Креды Selectel для DNS — сервис-пользователь + проект, где заведена зона
# (Keystone, как у провиженинга). Если DNS живёт в другом проекте/скоупе —
# задайте PLATFORM_DNS_SEL_*; иначе берутся SELECTEL_* (фолбэк).
# PLATFORM_DNS_SEL_ACCOUNT_ID=
# PLATFORM_DNS_SEL_USERNAME=
# PLATFORM_DNS_SEL_PASSWORD=
# PLATFORM_DNS_SEL_PROJECT_ID=
# PLATFORM_DNS_SEL_PROJECT_NAME=
# Legacy Рег.ру (PLATFORM_DNS_PROVIDER=regru):
# PLATFORM_DNS_REGRU_USERNAME=
# PLATFORM_DNS_REGRU_PASSWORD=

# Пул временных доменов: цель свободных имён, батч на тик (~45 c), TTL записей
# и IP-плейсхолдер свободных имён (адрес lab/ЛК). Без плейсхолдера пул спит.
# CLOUD_DOMAIN_POOL_TARGET=100
# CLOUD_DOMAIN_POOL_BATCH=10
# CLOUD_DOMAIN_POOL_TTL=60
# CLOUD_DOMAIN_POOL_PLACEHOLDER_IP=
